# KIS Developers Open API 인증 정보
# 실제 값은 이 파일을 복사해서 .env 로 만든 뒤 채워넣으세요. (.env는 git에 커밋되지 않습니다)

KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NO=your_account_number_here

# vps = 모의투자(openapivts.koreainvestment.com:29443), prod = 실전투자(openapi.koreainvestment.com:9443)
KIS_TRADING_MODE=vps

# ---- 아래는 GCP(Google Cloud)에 배포할 때만 설정 (로컬 실행 시엔 비워두면 됨) ----

# true로 설정하면 위 KIS_APP_KEY/SECRET/ACCOUNT_NO 대신 GCP Secret Manager에서 값을 읽는다.
# 이 경우 Secret Manager에 kis-app-key / kis-app-secret / kis-account-no 이름으로 시크릿을 등록해야 함.
USE_GCP_SECRET_MANAGER=false
GCP_PROJECT_ID=

# Cloud Run Job처럼 실행마다 컨테이너가 초기화되는 환경에서 SQLite DB를 보존하려면 설정.
# 비워두면 로컬 디스크만 사용 (VM 상시 실행 환경은 비워둬도 됨).
GCS_BUCKET_NAME=
GCS_DB_BLOB_NAME=candles.db

# 수집 실패 시 Slack 알림을 받고 싶다면 Incoming Webhook URL 입력 (선택사항).
SLACK_WEBHOOK_URL=
