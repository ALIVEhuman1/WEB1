<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:title="설정"
        app:titleTextColor="@color/white"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="알람"
                android:textSize="13sp"
                android:fontFamily="@font/pretendard_bold"
                android:textColor="@color/text_secondary"
                android:paddingStart="6dp"
                android:paddingBottom="10dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="1.5dp"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Alarm sound row -->
                    <LinearLayout
                        android:id="@+id/rowAlarmSound"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="18dp"
                        android:background="?attr/selectableItemBackground">

                        <FrameLayout
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:layout_marginEnd="14dp"
                            android:background="@drawable/bg_badge_blue">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_bell"
                                app:tint="@color/primary"
                                android:contentDescription="@null" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="알람 소리"
                                android:textSize="15sp"
                                android:fontFamily="@font/pretendard_bold"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:id="@+id/tvAlarmName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:textSize="13sp"
                                android:fontFamily="@font/pretendard_medium"
                                android:textColor="@color/text_secondary" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/slate_300"
                            android:contentDescription="@null" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/background"
                        android:layout_marginStart="18dp"
                        android:layout_marginEnd="18dp" />

                    <!-- Volume row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <FrameLayout
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:layout_marginEnd="14dp"
                                android:background="@drawable/bg_badge_green">

                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_volume"
                                    app:tint="@color/accent"
                                    android:contentDescription="@null" />

                            </FrameLayout>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="알람 볼륨"
                                android:textSize="15sp"
                                android:fontFamily="@font/pretendard_bold"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:id="@+id/tvVolumeValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:fontFamily="@font/pretendard_extrabold"
                                android:textColor="@color/accent" />

                        </LinearLayout>

                        <SeekBar
                            android:id="@+id/seekVolume"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:max="100"
                            android:progressTint="@color/accent"
                            android:thumbTint="@color/accent"
                            android:progressBackgroundTint="@color/border_light" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="단계가 끝나면 선택한 소리와 볼륨으로 알람이 울립니다."
                android:textSize="12sp"
                android:lineSpacingExtra="3dp"
                android:fontFamily="@font/pretendard_medium"
                android:textColor="@color/hint"
                android:padding="14dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
