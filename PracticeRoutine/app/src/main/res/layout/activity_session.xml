<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_session">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:title="진행 중"
        app:titleTextColor="@color/white"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/white" />

    <!-- Center content (scrollable so landscape/tablet never clips, long notes scroll) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp">

        <!-- Step pill -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_pill_white"
            android:elevation="2dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvCurrentStep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:fontFamily="@font/pretendard_bold"
                android:textColor="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="단계"
                android:textSize="13sp"
                android:fontFamily="@font/pretendard_medium"
                android:textColor="@color/hint" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvCurrentName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center"
            android:textSize="24sp"
            android:fontFamily="@font/pretendard_extrabold"
            android:textColor="@color/text_primary" />

        <!-- Circular timer ring -->
        <FrameLayout
            android:layout_width="266dp"
            android:layout_height="266dp"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="26dp">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progressTimer"
                android:layout_width="266dp"
                android:layout_height="266dp"
                android:layout_gravity="center"
                android:max="100"
                android:progress="100"
                android:indeterminate="false"
                app:indicatorColor="@color/primary"
                app:trackColor="@color/track_grey"
                app:indicatorSize="252dp"
                app:trackThickness="14dp"
                app:trackCornerRadius="8dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="62sp"
                    android:fontFamily="@font/pretendard_extrabold"
                    android:textColor="@color/text_primary"
                    android:includeFontPadding="false" />

                <TextView
                    android:id="@+id/tvPausedLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="일시정지"
                    android:textSize="13sp"
                    android:fontFamily="@font/pretendard_bold"
                    android:textColor="@color/hint"
                    android:letterSpacing="0.12"
                    android:visibility="gone" />

            </LinearLayout>

        </FrameLayout>

        <!-- Step note (hidden when empty) -->
        <LinearLayout
            android:id="@+id/noteCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_round16"
            android:elevation="1dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="22dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:layout_marginEnd="6dp"
                    android:src="@drawable/ic_edit"
                    app:tint="@color/secondary"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="메모"
                    android:textSize="12sp"
                    android:fontFamily="@font/pretendard_bold"
                    android:textColor="@color/secondary"
                    android:letterSpacing="0.02" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:lineSpacingExtra="3dp"
                android:fontFamily="@font/pretendard_medium"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        <!-- Next preview card -->
        <LinearLayout
            android:id="@+id/nextCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_round16"
            android:elevation="1dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="13dp"
            android:paddingBottom="13dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="다음"
                android:textSize="12sp"
                android:fontFamily="@font/pretendard_bold"
                android:textColor="@color/hint"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/tvNextStep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textSize="15sp"
                android:fontFamily="@font/pretendard_bold"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Bottom controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="26dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmNext"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:text="다음으로"
            android:textSize="19sp"
            android:fontFamily="@font/pretendard_extrabold"
            android:textColor="@color/white"
            android:backgroundTint="@color/error"
            app:cornerRadius="18dp"
            app:icon="@drawable/ic_arrow_next"
            app:iconGravity="textEnd"
            app:iconTint="@color/white"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/controlRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPauseResume"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:text="일시정지"
                android:textSize="16sp"
                android:fontFamily="@font/pretendard_bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/primary"
                app:cornerRadius="18dp"
                app:icon="@drawable/ic_pause"
                app:iconGravity="textStart"
                app:iconTint="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNext"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginEnd="12dp"
                android:textColor="@color/text_secondary"
                app:strokeColor="@color/slate_300"
                app:strokeWidth="1.5dp"
                app:cornerRadius="18dp"
                app:icon="@drawable/ic_skip"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@color/text_secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStop"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:backgroundTint="@color/red_bg"
                android:textColor="@color/error"
                app:strokeColor="@color/red_border"
                app:strokeWidth="1.5dp"
                app:cornerRadius="18dp"
                app:icon="@drawable/ic_stop"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@color/error" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
