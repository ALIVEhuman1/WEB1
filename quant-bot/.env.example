# KIS Developers Open API 인증 정보
# 실제 값은 이 파일을 복사해서 .env 로 만든 뒤 채워넣으세요. (.env는 git에 커밋되지 않습니다)

KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NO=your_account_number_here

# vps = 모의투자(openapivts.koreainvestment.com:29443), prod = 실전투자(openapi.koreainvestment.com:9443)
KIS_TRADING_MODE=vps
